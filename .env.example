# Datadog Configuration
DD_API_KEY=your_datadog_api_key_here
DD_APP_KEY=your_datadog_app_key_here
DD_SITE=datadoghq.com

# Service Configuration
DD_SERVICE=grv-api
DD_ENV=prod
DD_VERSION=v1.0.0
DD_TAGS=team:backend,owner:grv-team

# Agent Configuration
DD_HOSTNAME=auto
DD_PROCESS_AGENT_ENABLED=true
DD_LOGS_ENABLED=true
DD_LOGS_CONFIG_CONTAINER_COLLECT_ALL=true
DD_CONTAINER_EXCLUDE=name:dd-agent
DD_AC_INCLUDE=true
DD_APM_ENABLED=true
DD_APM_NON_LOCAL_TRAFFIC=true

# Database Configuration
DD_POSTGRES_HOST=localhost
DD_POSTGRES_PORT=5432
DD_POSTGRES_DB=grv_prod
DD_POSTGRES_USER=grv_user
DD_POSTGRES_PASSWORD=

# Redis Configuration
DD_REDIS_HOST=localhost
DD_REDIS_PORT=6379
DD_REDIS_DB=0
DD_REDIS_PASSWORD=

# Nginx Configuration
DD_NGINX_STATUS_URL=http://localhost:8080/nginx_status
DD_NGINX_LOG_PATH=/var/log/nginx/access.log
DD_NGINX_ERROR_LOG_PATH=/var/log/nginx/error.log

# Application Configuration
DJANGO_SETTINGS_MODULE=grv.settings.prod
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_INCLUDE_TRACE_ID=true

# Monitoring Thresholds
ERROR_RATE_THRESHOLD=5.0
LATENCY_P95_THRESHOLD=2000
LATENCY_P99_THRESHOLD=5000
CPU_THRESHOLD=80.0
MEMORY_THRESHOLD=85.0
DISK_THRESHOLD=90.0

# Celery Monitoring
CELERY_TASK_FAILURE_THRESHOLD=10
CELERY_QUEUE_BACKLOG_THRESHOLD=100
CELERY_WORKER_THRESHOLD=5

# Database Monitoring
DB_CONNECTION_THRESHOLD=80
DB_SLOW_QUERY_THRESHOLD=1000
DB_LOCK_THRESHOLD=10

# Redis Monitoring
REDIS_MEMORY_THRESHOLD=80
REDIS_EVICTION_THRESHOLD=100
REDIS_BLOCKED_CLIENTS_THRESHOLD=10
