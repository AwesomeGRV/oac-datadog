{
  "name": "[GRV-API] PostgreSQL Slow Queries",
  "type": "query alert",
  "query": "sum(last_15m):sum:postgresql.queries.duration{service:grv-api,env:prod}.by('query').filter(query:*) > {{.Env.DB_SLOW_QUERY_THRESHOLD | default \"1000\"}}",
  "message": "Slow PostgreSQL queries detected.\n\nQuery: {{query.name}}\nDuration: {{value}}ms\nEnvironment: {{env}}\nService: {{service}}\n\nAction: Review and optimize slow queries.",
  "tags": [
    "service:grv-api",
    "env:prod",
    "team:backend",
    "owner:grv-team",
    "monitor_type:database",
    "severity:warning"
  ],
  "options": {
    "notify_audit": false,
    "locked": false,
    "timeout_h": 0,
    "silenced": {},
    "include_tags": true,
    "new_host_delay": 300,
    "require_full_window": true,
    "notify_no_data": false,
    "renotify_interval": 60,
    "escalation_message": "Slow queries continue to impact performance.",
    "evaluation_delay": 300,
    "thresholds": {
      "critical": 5000,
      "warning": 1000,
      "critical_recovery": 500,
      "warning_recovery": 200
    }
  },
  "priority": 3
}
